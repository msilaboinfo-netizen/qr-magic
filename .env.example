PORT=3333
# 管理画面・API用（自分だけが知る長い文字列）
ADMIN_TOKEN=change-me-to-a-long-random-string
# 観客QRに載せるパス用（推測されにくい文字列）例: https://あなたのドメイン/r/この値
PUBLIC_TOKEN=change-me-public-slug

# --- インターネット公開（Cloudflare Tunnel など）---
# トンネルが表示した https URL をそのまま貼る（末尾の / は不要）
# 例: PUBLIC_BASE_URL=https://words-here.trycloudflare.com
PUBLIC_BASE_URL=
# トンネルを使うときは 1 にする（https を正しく扱う）
TRUST_PROXY=1

# --- Render を楽に再デプロイ（任意）---
# Render → サービス → Settings → Deploy Hook の URL をそのまま貼る
# あと PC で: npm.cmd run deploy
RENDER_DEPLOY_HOOK=

# --- 名刺URLなどをデプロイ後も残す（推奨・Render 無料ディスクは消える）---
# Supabase でプロジェクト作成 → SQL で qr-magic-app-state.sql（または sql/ 内の同名）を実行
# Project Settings → API → service_role（秘密）をコピー（ブラウザに出さない）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- YouTube「できるだけ即再生」用（任意）---
# 設定すると /yt-top が再生数上位動画へ直接リダイレクト。
# 未設定時は YouTube 検索結果へフォールバック。
YOUTUBE_API_KEY=

# --- Render に上の 2 本を API で一括設定（ブラウザで Environment を触らない）---
# Account Settings → API Keys で作成したキー（rnd_...）
RENDER_API_KEY=
# サービス画面の URL に含まれる srv-xxxx 形式
RENDER_SERVICE_ID=
